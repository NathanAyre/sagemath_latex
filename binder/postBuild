#!/bin/bash
set -e

# -------------------------
# Install helper scripts
# -------------------------
mkdir -p /home/jovyan/.local/bin
cp sagetex-run.py /home/jovyan/.local/bin/
cp compile-latex.sh /home/jovyan/.local/bin/
chmod +x /home/jovyan/.local/bin/sagetex-run.py
chmod +x /home/jovyan/.local/bin/compile-latex.sh

echo 'export PATH="/home/jovyan/.local/bin:$PATH"' >> /home/jovyan/.bashrc
# -------------------------
# Jupyter config
# -------------------------
mkdir -p /home/jovyan/.jupyter
mkdir -p /home/jovyan/.sage/jupyter-4.1

cat <<EOF > /home/jovyan/.jupyter/jupyter_server_config.py
c = get_config()
c.LatexConfig.shell_escape = 'allow'
c.LatexConfig.latex_command = 'tectonic'
EOF

cp /home/jovyan/.jupyter/jupyter_server_config.py /home/jovyan/.sage/jupyter-4.1/

# -------------------------
# Silence NodeJS warning
# -------------------------
cat <<EOF > /home/jovyan/.jupyter/jupyter_lab_config.py
import logging

class NoNodeJSWarningFilter(logging.Filter):
    def filter(self, record):
        return 'Could not determine jupyterlab build status without nodejs' not in record.getMessage()

logging.getLogger('LabApp').addFilter(NoNodeJSWarningFilter())
EOF

# -------------------------
# Sage init file
# -------------------------
mkdir -p /home/jovyan/.sage
cp init.sage /home/jovyan/.sage/init.sage

# -------------------------
# Texmf (optional but useful)
# -------------------------
mkdir -p /home/jovyan/texmf
cp -a /srv/conda/envs/notebook/share/texmf/. /home/jovyan/texmf

# -------------------------
# Enable extensions
# -------------------------
jupyter server extension enable --py jupyter_offlinenotebook --sys-prefix
jupyter server extension enable --py jupyterlab_latex --sys-prefix
